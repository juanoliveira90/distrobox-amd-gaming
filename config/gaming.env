# Configuration for the gaming distrobox. Sourced by every script in scripts/.
# Edit paths here; the scripts never hardcode them.

BOX_NAME=gaming
BOX_IMAGE=docker.io/cachyos/cachyos-v3:latest

# Dedicated home for the box — keeps Steam/Wine/emulator state separate from
# the host home. Proton prefixes and Steam libraries should live here (btrfs),
# not on the NTFS HDD.
BOX_HOME="$HOME/distrobox/gaming"

# ROMs / BIOS / game files on the external HDD (NTFS, auto-mounted by udisks2).
GAMES_ROOT="/run/media/juan/HDD/Games"
BIOS_ROOT="$GAMES_ROOT/Bios"

# Packages from the CachyOS / Arch repos (installed with pacman).
PACMAN_PACKAGES=(
  # base tools
  base-devel git curl wget unzip 7zip rsync
  # GPU (AMD RADV, 64-bit + 32-bit)
  mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon
  vulkan-icd-loader lib32-vulkan-icd-loader vulkan-tools mesa-utils
  # audio / desktop glue
  pipewire pipewire-pulse lib32-libpulse xdg-utils desktop-file-utils
  # native gaming
  steam proton-cachyos mangohud lib32-mangohud goverlay
  gamescope wine winetricks protontricks lutris
)

# Packages from the AUR (installed with paru). If a name later moves into the
# CachyOS repos, pacman is tried first automatically.
AUR_PACKAGES=(
  # pcsx2 is no longer in the Arch/CachyOS repos; -latest-bin tracks the
  # rolling 2.x release (the old stable had a GS renderer crash, see reference)
  pcsx2-latest-bin
  duckstation-qt-bin
  rpcs3-bin
  heroic-games-launcher-bin
  # adds emulator ROMs to the Steam library with artwork (see 06-setup-srm.sh)
  steam-rom-manager-bin
)

# Apps exported to the host application menu. distrobox-export matches these
# case-insensitively against desktop entries inside the box, so simple
# lowercase names work even for reverse-DNS files like net.lutris.Lutris.
EXPORT_APPS=(
  steam
  heroic
  lutris
  duckstation
  pcsx2
  rpcs3
  steam-rom-manager
  goverlay
)
