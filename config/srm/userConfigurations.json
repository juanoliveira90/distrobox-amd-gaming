[
  {
    "parserType": "Glob",
    "configTitle": "PlayStation 1 - DuckStation",
    "steamDirectory": "${steamdirglobal}",
    "romDirectory": "${romsdirglobal}/PS1",
    "steamCategories": ["PS1"],
    "executableArgs": "-batch -fullscreen -nogui \"${filePath}\"",
